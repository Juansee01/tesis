# Copy this to airflow/.env and fill in the values
# NEVER commit .env to git

FERNET_KEY=your_fernet_key_here
AZURE_TENANT_ID=your_azure_tenant_id
AZURE_CLIENT_ID=your_service_principal_client_id
AZURE_CLIENT_SECRET=your_service_principal_client_secret

# Fabric workspace and lakehouse IDs (from Fabric UI URL)
FABRIC_WORKSPACE_ID=your_workspace_id
FABRIC_LAKEHOUSE_ID=your_lakehouse_id

# Full ABFS path: abfss://<workspace_id>@onelake.dfs.fabric.microsoft.com/<lakehouse_id>
ONELAKE_ABFSS=abfss://your_workspace_id@onelake.dfs.fabric.microsoft.com/your_lakehouse_id

# Azure Storage for Airflow remote logs
AIRFLOW_REMOTE_LOG_FOLDER=wasbs://airflow-logs@yourstorageaccount.blob.core.windows.net/

# Fabric notebook item IDs (from Fabric UI, each notebook has a GUID)
NOTEBOOK_ID_BRONZE_TO_SILVER=your_notebook_guid
NOTEBOOK_ID_ML_TRAIN=your_notebook_guid
NOTEBOOK_ID_ML_INFER=your_notebook_guid
